# -----------------------------------------------------------------------------
# Frontend (Vite) - values exposed to browser
# -----------------------------------------------------------------------------
VITE_PUBLIC_BASE_URL=https://where2beach.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional fallback key name used in code
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional app feature flags
VITE_USE_MOCK_CROWD=false
VITE_FORCE_REMOTE_REPORTS=false
VITE_REPORTS_POLL_MS=60000
# Optional App Store / Play Store review URL used in Account > Recensisci
VITE_APP_REVIEW_URL=

# -----------------------------------------------------------------------------
# Serverless API (Vercel functions) - private
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional for automated schema migrations (CLI linked mode)
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
# Optional alternative for automated migrations without linked mode
# SUPABASE_DB_URL=postgresql://...
# App gate key (set either raw key OR sha256 hash, hash is preferred)
APP_ACCESS_KEY=
# APP_ACCESS_KEY_HASH=sha256:<64_hex_chars>

# -----------------------------------------------------------------------------
# Legal / iubenda (runtime config served by /api/legal-config)
# -----------------------------------------------------------------------------
# Optional direct URLs (recommended: copy from iubenda "Direct link")
LEGAL_PRIVACY_URL=https://www.iubenda.com/privacy-policy/93638969
LEGAL_COOKIE_URL=https://www.iubenda.com/privacy-policy/93638969/cookie-policy
# Optional legal contact email shown on fallback pages
LEGAL_CONTACT_EMAIL=privacy@where2beach.com
# Optional IDs used for automatic URL fallback + cookie banner loader
IUBENDA_SITE_ID=
IUBENDA_COOKIE_POLICY_ID=
IUBENDA_PRIVACY_POLICY_ID=
IUBENDA_LANG=it
IUBENDA_AUTO_BLOCKING=1

# Optional debug/test toggles
SIGNUP_TEST_MODE=0
SIGNUP_DEBUG=0
REPORTS_TEST_MODE=0
REPORTS_RATE_LIMIT_MIN=10
REPORTS_LOOKBACK_HOURS=6
REPORTS_GET_LIMIT=5000
REPORTS_HASH_SALT=
REPORTS_RETENTION_DAYS=30
REPORTS_PRUNE_TOKEN=
ANALYTICS_RATE_LIMIT=60
ANALYTICS_SALT=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-nano
OPENAI_CHAT_COMPLEX_MODEL=
OPENAI_CHAT_COMPLEX_ROUTING=0
OPENAI_CHAT_REASONING_EFFORT=low
OPENAI_CHAT_MAX_OUTPUT_TOKENS=180
OPENAI_CHAT_MAX_OUTPUT_TOKENS_COMPLEX=220
OPENAI_CHAT_TIMEOUT_MS=15000
OPENAI_CHAT_RATE_LIMIT=15
OPENAI_CHAT_RESPONSE_CACHE_TTL_SEC=43200
OPENAI_CHAT_RESPONSE_CACHE_MAX_ITEMS=600
OPENAI_CHAT_DAILY_TOKEN_BUDGET=120000
CHATBOT_SALT=
SIGNUP_HASH_SALT=
CRON_SECRET=
BEACH_ENRICH_DAILY_TARGET=40
BEACH_ENRICH_RUN_CAP=10
BEACH_ENRICH_REFRESH_DAYS=30
BEACH_PROFILE_PUBLISH_THRESHOLD=0.85
BEACH_ENRICH_MAX_REVIEW_ROUNDS=3
BEACH_ENRICH_EXTRACT_MODEL=gpt-5.4-nano
BEACH_ENRICH_REVIEW_MODEL=gpt-5.4
GOOGLE_PLACES_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BEACH_ENRICH_TEST_MODE=0
ENABLE_DOUBLE_OPTIN=0
TEST_RATE_LIMIT=10
SIGNUP_RATE_LIMIT_MAX=10
SIGNUP_RATE_LIMIT_WINDOW_SEC=600
# Optional: defaults to waitlist_rate_limit_touch for backward compatibility
SIGNUP_RATE_LIMIT_RPC=
# Optional: defaults to waitlist_signups for backward compatibility
SIGNUP_TABLE=

# Business requests (landing + account CTA)
BUSINESS_REQUEST_TABLE=business_requests
BUSINESS_RATE_LIMIT_MAX=8
BUSINESS_RATE_LIMIT_WINDOW_SEC=600
BUSINESS_LEADS_NOTIFY_TO=info@where2beach.com
BUSINESS_FROM=
BUSINESS_REPLY_TO=

# Optional double opt-in email
RESEND_API_KEY=
SIGNUP_FROM=
SIGNUP_CONFIRM_URL=

# -----------------------------------------------------------------------------
# Local scripts / poster generation
# -----------------------------------------------------------------------------
NOMINATIM_EMAIL=
NOMINATIM_USER_AGENT=
PUBLIC_BASE_URL=https://where2beach.com
POSTER_ONLY_SRC=
POSTER_DEBUG_PLATE=0
POSTER_DEBUG_URL=0

# -----------------------------------------------------------------------------
# Test/smoke runner (optional)
# -----------------------------------------------------------------------------
BASE_URL=http://127.0.0.1:3000
HOST=127.0.0.1
PORT=3000
SMOKE_READY_TIMEOUT_MS=12000
SMOKE_VERIFY_CLEANUP=0
SMOKE_TEST_NO_READY=0

# -----------------------------------------------------------------------------
# Mobile app (Expo) - public at build time
# -----------------------------------------------------------------------------
EXPO_PUBLIC_BASE_URL=https://where2beach.com
# Required for mobile access to gated /app route
EXPO_PUBLIC_APP_ACCESS_KEY=
EXPO_PUBLIC_API_TIMEOUT_MS=12000
# QA only: allow report submit without distance geofence
EXPO_PUBLIC_REPORT_ANYWHERE=0
