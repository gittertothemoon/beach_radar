{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "eas:build:android:dev": "npx eas-cli build --platform android --profile development",
    "eas:build:android:preview": "npx eas-cli build --platform android --profile preview",
    "eas:build:android:prod": "npx eas-cli build --platform android --profile production",
    "eas:build:ios:dev": "npx eas-cli build --platform ios --profile development",
    "eas:build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "eas:build:ios:prod": "npx eas-cli build --platform ios --profile production",
    "eas:submit:ios:prod": "npx eas-cli submit --platform ios --latest --profile production --wait",
    "eas:submit:android:prod": "npx eas-cli submit --platform android --latest --profile production --wait"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~54.0.0",
    "expo-crypto": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
