{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.5.28"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "off"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "www.where2beach.com" }
      ],
      "destination": "https://where2beach.com/$1",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/landing/",
      "permanent": false
    },
    {
      "source": "/landing",
      "destination": "/landing/",
      "permanent": true
    },
    {
      "source": "/waitlist",
      "destination": "/landing/",
      "permanent": true
    },
    {
      "source": "/waitlist/(.*)",
      "destination": "/landing/",
      "permanent": true
    },
    {
      "source": "/register",
      "destination": "/register/",
      "permanent": true
    },
    {
      "source": "/app/register",
      "destination": "/register/",
      "permanent": false
    },
    {
      "source": "/app/register/(.*)",
      "destination": "/register/",
      "permanent": false
    },
    {
      "source": "/app",
      "has": [{ "type": "query", "key": "key" }],
      "destination": "/api/app-access",
      "permanent": false
    },
    {
      "source": "/app",
      "missing": [{ "type": "cookie", "key": "br_app_access", "value": "1" }],
      "destination": "/landing/",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "/app/",
      "permanent": false
    },
    {
      "source": "/app/",
      "has": [{ "type": "query", "key": "key" }],
      "destination": "/api/app-access",
      "permanent": false
    },
    {
      "source": "/app/(.*)",
      "has": [{ "type": "query", "key": "key" }],
      "destination": "/api/app-access?path=/app/$1",
      "permanent": false
    },
    {
      "source": "/app/(.*)",
      "missing": [{ "type": "cookie", "key": "br_app_access", "value": "1" }],
      "destination": "/landing/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/landing/",
      "destination": "/landing/index.html"
    },
    {
      "source": "/register/",
      "destination": "/app-shell/index.html"
    },
    {
      "source": "/app/",
      "has": [{ "type": "cookie", "key": "br_app_access", "value": "1" }],
      "destination": "/app-shell/index.html"
    },
    {
      "source": "/app/(.*)",
      "has": [{ "type": "cookie", "key": "br_app_access", "value": "1" }],
      "destination": "/app-shell/index.html"
    }
  ]
}
