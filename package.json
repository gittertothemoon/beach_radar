{
  "name": "where2beach",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "landing:dev": "node scripts/run-landing-dev.mjs",
    "landing:build": "npm --prefix w2b-hero run build",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck",
    "preview": "vite preview",
    "test:reports:api": "playwright test tests/reports.api.spec.ts",
    "test:app": "playwright test tests/app.gating.spec.ts tests/app.auth.spec.ts tests/app.auth.resume.spec.ts tests/app.map.spec.ts tests/app.reports.spec.ts tests/app.favorites.spec.ts",
    "test:app:auth": "playwright test tests/app.auth.spec.ts tests/app.auth.resume.spec.ts",
    "test:app:gating": "playwright test tests/app.gating.spec.ts",
    "test:app:map": "playwright test tests/app.map.spec.ts",
    "test:app:reports": "playwright test tests/app.reports.spec.ts",
    "test:app:favorites": "playwright test tests/app.favorites.spec.ts",
    "seed:geocode": "node scripts/seed/geocode.mjs",
    "seed:sync": "node scripts/seed/sync.mjs && npm run seed:validate",
    "seed:validate": "node scripts/seed/validate.mjs",
    "assets:sync": "node scripts/sync-brand-assets.mjs",
    "assets:check": "node scripts/sync-brand-assets.mjs --check",
    "repo:hygiene": "node scripts/repo-hygiene.mjs",
    "check:all": "npm run check && npm run repo:hygiene && npm run assets:check",
    "supabase:fix-env": "node scripts/supabase-ops.mjs fix-env",
    "supabase:doctor": "node scripts/supabase-ops.mjs doctor",
    "supabase:init": "node scripts/supabase-ops.mjs init",
    "supabase:migrations:sync": "node scripts/supabase-ops.mjs sync-migrations",
    "supabase:migrate": "node scripts/supabase-ops.mjs migrate",
    "supabase:auto": "node scripts/supabase-ops.mjs all --fix-env",
    "security:sinks": "node scripts/ci/security-sinks-check.mjs",
    "security:smoke": "node scripts/ci/security-smoke.mjs",
    "security:advisors": "node scripts/ci/supabase-advisors-check.mjs",
    "posters:csv": "node tools/posters/make-csv.mjs",
    "posters:gen": "node tools/posters/generate.mjs",
    "video:dev": "npm --prefix remotion run dev",
    "video:render": "npm --prefix remotion run render",
    "video:render:bomb-pack": "npm --prefix remotion run render:bomb-pack",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:ios": "node scripts/run-mobile-ios-dev.mjs",
    "mobile:ios:expo": "npm --prefix mobile run ios",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "mobile:build:android:dev": "npm --prefix mobile run eas:build:android:dev",
    "mobile:build:android:preview": "npm --prefix mobile run eas:build:android:preview",
    "mobile:build:android:prod": "npm --prefix mobile run eas:build:android:prod",
    "mobile:build:ios:dev": "npm --prefix mobile run eas:build:ios:dev",
    "mobile:build:ios:preview": "npm --prefix mobile run eas:build:ios:preview",
    "mobile:build:ios:prod": "npm --prefix mobile run eas:build:ios:prod"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.2",
    "leaflet": "^1.9.4",
    "pngjs": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.0",
    "@types/leaflet": "^1.9.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.5.28",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.3",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
